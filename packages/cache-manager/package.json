{
  "name": "cache-manager",
  "version": "7.2.9",
  "description": "Cache Manager for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf ./dist ./coverage ./node_modules",
    "lint": "biome check --write --error-on-warnings",
    "test": "pnpm lint && vitest run --coverage",
    "test:ci": "biome check --error-on-warnings && vitest run --coverage",
    "build": "rimraf ./dist && tsdown src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaredwray/cacheable.git",
    "directory": "packages/cache-manager"
  },
  "keywords": [
    "cache",
    "caching",
    "cache manager",
    "node",
    "node.js",
    "in-memory cache",
    "redis",
    "memcached",
    "multi-store cache",
    "ttl",
    "caching layer",
    "cache abstraction",
    "cache middleware",
    "cache strategies",
    "cache wrapper"
  ],
  "authors": [
    {
      "name": "Jared Wray",
      "email": "me@jaredwray.com"
    },
    {
      "name": "Tim Phan",
      "email": "timphan.dev@gmail.com"
    }
  ],
  "license": "MIT",
  "dependencies": {
    "@cacheable/utils": "workspace:^",
    "keyv": "^5.6.0"
  },
  "devDependencies": {
    "@keyv/redis": "^5.1.6",
    "cache-manager-redis-yet": "^5.1.5",
    "cacheable": "workspace:^",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  }
}
